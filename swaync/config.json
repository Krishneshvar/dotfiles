{
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",

  "control-center-width": 380,
  "control-center-margin-top": 12,
  "control-center-margin-right": 12,

  "notification-window-width": 360,
  "notification-icon-size": 48,

  "widgets": [
    "title",
    "dnd",
    "notifications",
    "backlight#screen",
    "volume",
    "buttons-grid#system",
    "buttons-grid#toggles"
  ],

  "widget-config": {

    "title": {
      "text": "Notification Center"
    },

    "dnd": {
      "text": "Do Not Disturb"
    },

    "volume": {
      "label": "󰓃 "
    },

    "backlight#screen": {
      "label": "󰖨 ",
      "device": "intel_backlight",
      "min": 1
    },

    "buttons-grid#system": {
      "buttons-per-row": 4,
      "actions": [
        {
          "label": "󰐥",
          "command": "systemctl poweroff"
        },
        {
          "label": "󰌾",
          "command": "hyprlock"
        },
        {
          "label": "󰗼",
          "command": "hyprctl dispatch exit"
        },
        {
          "label": "󰜉",
          "command": "systemctl reboot"
        }
      ]
    },

    "buttons-grid#toggles": {
      "buttons-per-row": 4,
      "actions": [
        {
          "label": "󰒲",
          "command": "",
          "type": "toggle",
          "update-command": ""
        },
        {
          "label": "󰖩",
          "command": "nmcli radio wifi toggle",
          "type": "toggle",
          "update-command": "bash -c 'nmcli radio wifi | grep -q \"enabled\" && echo true || echo false'"
        },
        {
          "label": "󰂯",
          "command": "bash -c 'bluetoothctl power $(bluetoothctl show | grep -q \"Powered: yes\" && echo off || echo on)'",
          "type": "toggle",
          "update-command": "bash -c 'bluetoothctl show | grep -q \"Powered: yes\" && echo true || echo false'"
        },
        {
          "label": "󰍬",
          "command": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
          "type": "toggle",
          "update-command": "bash -c 'pactl get-source-mute @DEFAULT_SOURCE@ | grep -q \"Mute: yes\" && echo true || echo false'"
        }
      ]
    }

  }
}
